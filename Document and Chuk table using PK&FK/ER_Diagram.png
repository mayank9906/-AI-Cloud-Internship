s_device_based\":false,\"passed\":true},\"1521940286\":{\"name\":\"1521940286\",\"rule_id\":\"2dprGiDHsVr2AQRVuaPGLU\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":false},\"is_device_based\":false,\"group_name\":\"Control\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"1441592107\":{\"name\":\"1441592107\",\"rule_id\":\"13CqzLncS8cXlFM1d9IOPM:explore\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"should_disable_google_one_tap_on_mobile_web\":false},\"is_device_based\":true,\"group_name\":\"control\"},\"3861898381\":{\"name\":\"3861898381\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"max_file_uploads\":20},\"is_device_based\":false,\"passed\":false},\"1811233013\":{\"name\":\"1811233013\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"ads_segment_id\",\"value\":{\"consent_modal_enabled\":false,\"keepalive_event_logger_web\":false,\"ask_chatgpt_button_copy_key\":\"ASK_CHATGPT\",\"consent_modal_short_copy\":true,\"feedback_interested_enabled\":false,\"late_ads_event_discard_timeout_seconds\":5,\"late_ads_visibility_gate_enabled\":false,\"ask_about_ad_ephemeral_thread_panel\":false,\"show_ask_chatgpt_menu_item\":true,\"show_ask_chatgpt_button\":false,\"consent_modal_pre_selected\":true,\"consent_modal_title\":\"Make ads relevant for you\",\"android_display_zoom_scale_threshold\":0,\"consent_modal_variant\":\"\",\"late_ads_event_discard_timeout_after_slot_visibility_seconds\":1,\"late_ads_slot_visibility_threshold\":0.01},\"is_device_based\":false,\"is_in_layer\":true,\"explicit_parameters\":[\"ask_about_ad_ephemeral_thread_panel\",\"show_ask_chatgpt_button\",\"ask_chatgpt_button_copy_key\"],\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1355628363\":{\"name\":\"1355628363\",\"rule_id\":\"6EkzgQkSDT4MxFNtb5sHlF:100.00:5-6EkzgOFQbAViegfxzXx42D\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"prompts\":[{\"body\":\"Create a bright text-light mango tasting mat with simple sections for aroma, sweetness, texture and favourite, leaving labels blank.\",\"title\":\"Make a mango tasting mat\"},{\"body\":\"Create a text-light vertical backdrop for a music Reel. Use lively abstract shapes, no platform logos, and leave empty space for my caption.\",\"title\":\"Create a music Reel backdrop\"},{\"body\":\"Create a simple train ticket status flowchart with icons for CNF, RAC, WL and Tatkal. Keep labels short and editable.\",\"title\":\"Map train booking choices\"},{\"title\":\"Build a reading routine\",\"body\":\"Help me build a 20-minute reading routine. Ask me one question about when I can read, then suggest a first-week plan.\"},{\"title\":\"Learn to plan a short trip\",\"body\":\"Teach me how to plan a short trip from scratch. Ask one question about destination and dates, then build a simple itinerary outline.\"},{\"title\":\"Get into Wimbledon gently\",\"body\":\"Give me a fun Wimbledon 2026 primer: what makes grass-court tennis different, who to notice, and how to sound less lost.\"},{\"body\":\"Check the current Wimbledon schedule and suggest one match to follow from India, with the likely match time and one story to watch.\",\"title\":\"Pick a Wimbledon match\"},{\"title\":\"Polish a WhatsApp message\",\"body\":\"I need to send a tricky WhatsApp message. Ask me to paste it and say who it is for, then make it polite and natural.\"},{\"body\":\"Make my unit-test revision feel like a game. Ask my subject first, then give a 20-minute plan with quick rounds.\",\"title\":\"Turn revision into a game\"},{\"title\":\"Plan a rainproof commute\",\"body\":\"Make a rainy-day commute game plan. Ask my city and route first, then suggest backup transport, timing buffers and what to pack.\"},{\"title\":\"Make a cricket catch-up card\",\"body\":\"Give me a fun, no-jargon catch-up on the Women’s T20 World Cup, with India’s path, key players to notice, and one thing to watch today.\"},{\"body\":\"Build a light India vs England watch plan for July: match reminders, snack breaks, and a simple way to follow if I miss overs.\",\"title\":\"Plan a late-night cricket watch\"},{\"body\":\"Make a monthly kirana restock list. Ask my household size first, then organise staples, cleaning items and quick top-ups.\",\"title\":\"Build a kirana restock list\"},{\"body\":\"Explain today’s India monsoon update in plain English, including what normal, deficit and warning colours mean.\",\"title\":\"Read monsoon updates better\"},{\"title\":\"Build a monsoon travel buffer\",\"body\":\"Help me plan a monsoon journey with buffers for delays. Ask my city pair and travel mode, then make a practical backup plan.\"},{\"title\":\"Host a spoiler-free film chat\",\"body\":\"Make a spoiler-free debate guide for a current Indian film my friends have seen. Ask the film name, then give talking points.\"},{\"body\":\"Check the Wimbledon 2026 schedule and make me a simple IST viewing plan for the first week. Ask which players I care about.\",\"title\":\"Plan your Wimbledon viewing\"},{\"title\":\"Make a study quest map\",\"body\":\"Create a simple study quest map with 7 checkpoints, icons and blank labels. Ask me the subject first, then give label text separately.\"},{\"body\":\"Create a text-light pantry label-check poster with icons for MRP, expiry, ingredients, veg or non-veg symbol and storage.\",\"title\":\"Make a pantry check poster\"},{\"title\":\"Draw a rainy entryway\",\"body\":\"Create a simple text-light rainy entryway layout for an Indian flat: shoe zone, umbrella spot, drying mat and hooks. No brand names.\"},{\"title\":\"Get documents ready online\",\"body\":\"Help me prepare a DigiLocker-ready document set for admissions or a government service. Ask which task first.\"},{\"title\":\"Fix monsoon laundry\",\"body\":\"Make a monsoon laundry rota for a small home where clothes dry indoors. Include smell prevention, rainy-day backup and what to wash first.\"},{\"body\":\"Help me prepare for a Passport Seva appointment. Check official document guidance and ask one question about my application type.\",\"title\":\"Prepare Passport Seva papers\"},{\"title\":\"Set up DigiLocker basics\",\"body\":\"Explain DigiLocker in everyday terms and help me plan which documents to fetch, upload, or carry as originals.\"},{\"title\":\"Learn ride phrases\",\"body\":\"Teach me 8 polite phrases for an auto or cab ride. Ask my city or language first, then give pronunciation help.\"},{\"title\":\"Practise small talk lightly\",\"body\":\"Practise a 5-minute small-talk scene with me. Ask the setting first, then play the other person and keep it light.\"},{\"title\":\"Learn a topic with examples\",\"body\":\"Teach me a difficult topic using everyday examples. Ask me the topic first, then build a 10-minute lesson.\"},{\"body\":\"Plan 3 spill-proof tiffin ideas. Ask what I eat and whether I can reheat first, then keep it practical.\",\"title\":\"Pack a better tiffin\"},{\"body\":\"Make a first hostel packing list for India’s monsoon months. Ask my city and hostel rules first, then group must-haves and nice-to-haves.\",\"title\":\"Pack for hostel in the rains\"},{\"body\":\"Teach me how UPI AutoPay mandates work and give me a safe way to review subscriptions without sharing account details.\",\"title\":\"Review UPI AutoPay safely\"},{\"title\":\"Practise a meeting update\",\"body\":\"Practise a short meeting update with me. Give me a simple structure, then ask one question and correct my answer gently.\"},{\"title\":\"Draw a hostel packing map\",\"body\":\"Create a text-light packing map for a monsoon hostel or PG room: bedding, documents, footwear, laundry and desk. Use simple icons.\"},{\"body\":\"Help me make a practical monsoon plan for today: commute, footwear, laundry and bag essentials. Ask for my city first.\",\"title\":\"Rain-proof my day\"},{\"title\":\"Understand the new India names\",\"body\":\"Explain the young players people are discussing in India’s Ireland and England T20Is. Keep it beginner-friendly and avoid hype.\"},{\"title\":\"Share a UPI split politely\",\"body\":\"Write a clear, polite message to request a UPI split for a group expense. Keep it short and include a line asking people to verify payee name.\"},{\"title\":\"Plan a World Cup night\",\"body\":\"Make me a simple FIFA World Cup watch plan for India time. Ask which teams I follow, then suggest matches, snacks and a sleep-friendly routine.\"},{\"body\":\"Create a simple chore wheel with household task icons and blank name spaces. Ask how many people should fit on it first.\",\"title\":\"Create a chore wheel\"},{\"body\":\"Build a monsoon commute kit for my city and travel mode. Ask one question if needed, then group items as must-carry and optional.\",\"title\":\"Pack for monsoon commutes\"},{\"body\":\"Use current India music charts to build a 7-song playlist theme for a rainy commute. Avoid explicit lyrics unless I ask.\",\"title\":\"Build a rainy commute playlist\"},{\"title\":\"Create a match-night scoreboard\",\"body\":\"Create a text-light match-night scoreboard image for the Women’s T20 World Cup. Keep spaces blank for teams, runs, snacks, and MVP.\"},{\"body\":\"Make a grocery list that prevents random extras. Ask what I’m cooking this week, then group items by store section.\",\"title\":\"Build a smarter grocery run\"},{\"body\":\"I’ll paste only my ticket status, not my full PNR. Explain CNF, RAC or WL and tell me the next sensible check.\",\"title\":\"Decode my train status\"},{\"title\":\"Cook from fridge leftovers\",\"body\":\"Help me turn fridge leftovers into an Indian-style meal. I can upload a photo or list what I have.\"},{\"title\":\"Plan a short trip in India\",\"body\":\"Help plan a 2–3 day trip in India. First ask my starting city and rough budget, then suggest practical options.\"},{\"title\":\"Break down a charting song\",\"body\":\"Pick a song currently high on YouTube India and explain its hook, structure and replay value without quoting lyrics.\"},{\"title\":\"Learn cooker timing basics\",\"body\":\"Teach me pressure cooker basics for dal, rice and chana, including whistles, soaking and safety checks.\"},{\"title\":\"Storyboard a song hook\",\"body\":\"Create a 6-frame, text-light storyboard template for explaining why a current YouTube India song hook works, with no lyrics or artist likenesses.\"},{\"title\":\"Sort papers without panic\",\"body\":\"Give me a 30-minute game plan to sort household papers into keep, act and file piles. Ask what kind of papers I have first.\"},{\"title\":\"Pick a Van Mahotsav sapling\",\"body\":\"Help me pick one low-maintenance native sapling for Van Mahotsav. Ask my city and planting space, then give care steps.\"},{\"title\":\"Learn the World Cup knockout\",\"body\":\"Explain the FIFA World Cup knockout format for an India viewer, including how extra time and penalties work.\"},{\"title\":\"Make a match-night tracker\",\"body\":\"Create a text-light FIFA World Cup match-night tracker with blank team slots, score spaces, and room for IST timings.\"},{\"title\":\"Decode a talked-about squad pick\",\"body\":\"Give me a quick profile of a current India squad pick being searched a lot. Cover role, recent context and what to watch for.\"},{\"title\":\"Play mock interview ping-pong\",\"body\":\"Run a mock interview like ping-pong. Ask my role, then give one question at a time with a short coaching note after each answer.\"},{\"body\":\"Build a 5-day school or office tiffin rotation using Indian staples. Ask one question about dietary limits before suggesting.\",\"title\":\"Plan a tiffin rotation\"},{\"body\":\"Create a simple T20 fielding map for a new cricket fan using dots and zones, with any position names listed outside the image.\",\"title\":\"See field positions clearly\"},{\"title\":\"Understand Form 16 and AIS\",\"body\":\"Explain Form 16, AIS, 26AS and ITR in simple terms for AY 2026-27. Ask one question only if you need my income type.\"},{\"title\":\"Sort tiny UPI payments\",\"body\":\"Help me make a tiny-payment routine for chai, autos and kirana. Check current UPI Lite rules and remind me not to share PINs.\"},{\"body\":\"Explain gazetted, restricted and state holidays in India using the 2026 calendar. Give a simple rule for checking office or school closures.\",\"title\":\"Decode holiday types\"},{\"body\":\"Turn weekly chores into a fair, playful rota. Ask how many people are sharing, then suggest roles, swaps and a 10-minute reset.\",\"title\":\"Make chores less boring\"},{\"body\":\"Create a cosy, text-light image of an Indian monsoon snack board with chai, rain cues and blank label spaces.\",\"title\":\"Create a rainy-day snack board\"},{\"body\":\"Find three current India OTT trailers worth sampling tonight, then make a playful 30-minute no-spoiler watch plan.\",\"title\":\"Choose an OTT trailer night\"},{\"title\":\"Make a mini tennis bracket\",\"body\":\"Make a tiny Wimbledon bracket game I can use with friends, simple scoring, no expert knowledge needed.\"},{\"title\":\"Remix leftovers into dinner\",\"body\":\"Help me turn leftovers into dinner. Ask me for a fridge photo or ingredient list, then suggest 3 playful options with simple steps.\"},{\"title\":\"Make a tiffin idea wheel\",\"body\":\"Create a simple tiffin idea wheel with icons for grain, protein, veg, fruit and snack. Use blank labels, no brand names.\"},{\"title\":\"Discuss Kargil respectfully\",\"body\":\"Help me discuss Kargil Vijay Diwas in a balanced way for a study group. Give 5 questions that focus on history, courage and evidence.\"},{\"title\":\"Create a tennis bingo card\",\"body\":\"Create a text-light Wimbledon bingo card image for a home watch. Use simple icons and blank squares, no player likenesses or logos.\"},{\"title\":\"Sketch a better room layout\",\"body\":\"Create a simple layout sketch to make my desk or room easier to use. Ask for a photo or short description first.\"},{\"title\":\"Host a mango tasting\",\"body\":\"Suggest a playful mango tasting at home for National Mango Day. Include ways to compare flavour, texture, aroma and use.\"},{\"title\":\"Make a tennis score card\",\"body\":\"Create a clean, text-light tennis scorecard image for Wimbledon watching. Leave blanks for player names and sets. No logos.\"},{\"title\":\"Make a rainy commute card\",\"body\":\"Create a simple rainy-day commute safety card for India, using icons only and no location-specific claims.\"},{\"title\":\"Create a Reel storyboard\",\"body\":\"Create a simple 6-panel image storyboard for a 20-second everyday Reel. Keep it text-light and use blank caption boxes.\"},{\"title\":\"Reset my desk like a game\",\"body\":\"Help me reset my desk in 15 minutes. Ask me for a photo or short description, then turn it into 3 quick rounds.\"},{\"title\":\"Settle a UPI split politely\",\"body\":\"Help me write a polite message to split a UPI payment. Ask what was paid and the amount, then make it clear without sounding awkward.\"},{\"title\":\"Understand Rath Yatra quickly\",\"body\":\"Give me a friendly 5-minute guide to Puri Rath Yatra, including key words I’ll hear and respectful visitor basics.\"},{\"body\":\"Make a simple IST watch plan for the next FIFA World Cup 2026 matches I care about. Ask which teams I follow, then keep it realistic for workdays.\",\"title\":\"Plan a late-night World Cup watch\"},{\"title\":\"Design a drying corner\",\"body\":\"Create a text-light visual layout for a monsoon drying corner at home. Ask one question about space if needed.\"},{\"title\":\"Fix my match stream setup\",\"body\":\"Help me choose a reliable live-sport setup for home: TV, app or backup data. Ask what I’m watching and what devices I have.\"},{\"title\":\"Create a Rath Yatra story map\",\"body\":\"Create a simple text-light illustration of Puri Rath Yatra’s temple-to-Gundicha journey, with blank labels I can fill in.\"},{\"body\":\"Practise an interview for my role. Ask one question at a time, wait for my answer, then give brief feedback. First ask my role.\",\"title\":\"Practise interview answers\"},{\"title\":\"Write a service message\",\"body\":\"Help me write a short message to a driver, shop or technician in English and one Indian language I choose. Ask the language first.\"},{\"body\":\"Help me choose from current Hindi and pan-India theatrical releases. Ask my city and mood, then make a simple cinema plan.\",\"title\":\"Pick a cinema plan\"},{\"title\":\"Learn BGMI lag terms\",\"body\":\"Explain BGMI terms like ping, desync, FPS and server lag with simple examples a casual player would get.\"},{\"title\":\"Make a World Cup match tracker\",\"body\":\"Create a text-light World Cup match tracker image I can print. Use blank slots for teams, dates and predictions, with a clean football-night feel.\"},{\"body\":\"Show me how moon-sighting based holidays can shift on calendars. Use Muharram 2026 as the example and give a simple planning rule.\",\"title\":\"Check moon-sighting dates\"},{\"body\":\"Make a spoiler-light guide to India Women at the ICC Women’s T20 World Cup 2026. Include upcoming matches, storylines and terms to know.\",\"title\":\"Follow India Women with context\"},{\"title\":\"Create a match-night score card\",\"body\":\"Create a text-light printable score card for a FIFA World Cup watch night, with blank spaces for teams, predictions, and snacks.\"},{\"body\":\"Help me plan a safe Rath Yatra day in Puri. Ask my travel date and starting point, then make a realistic route and packing plan.\",\"title\":\"Plan a Rath Yatra day\"},{\"body\":\"Create a simple visual card for structuring interview answers using four blank sections and small icons. Keep text minimal.\",\"title\":\"Make an interview answer card\"},{\"title\":\"Plan a rain-safe commute\",\"body\":\"Help me plan a monsoon commute. Ask my city and usual route, then suggest what to check, carry and avoid today.\"},{\"title\":\"Plan a week of simple meals\",\"body\":\"Plan a week of simple meals. Ask one question about what I eat or have at home, then give meals and a shopping list for an Indian kitchen.\"},{\"body\":\"Create a clean weekly planner image with blank day blocks, priority space and simple symbols. Keep it mostly text-free.\",\"title\":\"Make a weekly planner page\"},{\"title\":\"Make a tiffin menu card\",\"body\":\"Create a text-light weekly tiffin menu card with simple food icons and blank spaces I can fill in.\"},{\"title\":\"Find a charting song angle\",\"body\":\"Use India’s current YouTube music charts to suggest one song-based Reel or Shorts idea. Keep it lyric-safe and easy to film.\"},{\"body\":\"Help me plan easy lunchbox ideas using what I usually buy. Ask my main staples, then keep it low-effort.\",\"title\":\"Plan easy lunchbox ideas\"},{\"title\":\"Make a water-check reminder\",\"body\":\"Create a text-light reminder card for a weekly stagnant-water check. Use simple home icons, no scary imagery.\"},{\"title\":\"Build a trending music queue\",\"body\":\"Use current India YouTube music trends to build a no-skip queue by mood. No lyrics, just why each pick fits.\"},{\"body\":\"Help me write a short leave request to my manager. Ask me for the dates and reason before drafting.\",\"title\":\"Draft a leave request\"},{\"title\":\"Make a football bracket map\",\"body\":\"Create a clean global football knockout explainer image with generic team icons, no logos, and minimal text. Add India-time notes outside it.\"},{\"title\":\"Pack for hostel in the rains\",\"body\":\"Make a monsoon move-in checklist for a hostel or PG. Ask me the city and room type first, then cover packing, documents and laundry.\"},{\"title\":\"Write a tactful work message\",\"body\":\"Turn my rough point into a polite but clear work message. Ask what happened, then draft it in 3 tones.\"},{\"title\":\"Make a trip packing board\",\"body\":\"Create a text-light packing mood board for a weekend trip. Ask my destination and travel style first.\"},{\"title\":\"Tame my inbox in 20 minutes\",\"body\":\"Give me a 20-minute inbox clean-up game with rules for reply, archive and park. Ask whether it is work or personal first.\"},{\"body\":\"Draft a polite apartment WhatsApp notice about a water or power issue. Ask for the timing and action needed, then keep it short.\",\"title\":\"Write a clear RWA message\"},{\"body\":\"Make a simple, camera-friendly hook-step idea for a trending India music video. Keep it original and easy to do at home.\",\"title\":\"Make a hook-step plan\"},{\"body\":\"Explain CNF, RAC, WL, PQWL and Tatkal in plain English, then help me decide what to check before booking a train ticket.\",\"title\":\"Decode train ticket status\"},{\"body\":\"Create a text-light Wimbledon watch bingo card image with tennis symbols, blank squares, and no official logos.\",\"title\":\"Create Wimbledon bingo cards\"},{\"title\":\"Make Wimbledon watch bingo\",\"body\":\"Create a Wimbledon watch bingo game for friends, with simple squares for rallies, crowd moments, and snack breaks.\"},{\"body\":\"Explain Kargil Vijay Diwas through a concise 1999 timeline, key geography and why 26 July is remembered in India.\",\"title\":\"Trace Kargil’s timeline\"},{\"title\":\"Build your World Cup watchlist\",\"body\":\"Check the latest FIFA World Cup fixtures and make me an IST watchlist for the next three nights. Ask which teams I follow.\"},{\"title\":\"Turn a trend into a clean idea\",\"body\":\"Help me adapt a trending Indian song into a respectful 15-second video idea. Ask what I’m filming, then give three options.\"},{\"title\":\"Draft a Reel idea\",\"body\":\"Turn my ordinary day into a 20-second Reel idea for Indian audiences. Ask the moment, then give shots, captions and audio mood.\"},{\"title\":\"Understand a textbook page\",\"body\":\"I’ll upload a page or paste a paragraph. Explain it in simple English, then give me three questions to check my understanding.\"},{\"body\":\"Explain India box-office terms like gross, net, occupancy and opening weekend using this month’s cinema releases.\",\"title\":\"Learn box-office basics\"},{\"title\":\"Map a STAR answer\",\"body\":\"Create a simple STAR answer map image with four blank boxes and neutral icons. Avoid logos, faces and long text.\"},{\"body\":\"Create a clean, text-light Wimbledon score tracker I can print, with blank match slots and spaces for sets.\",\"title\":\"Print a tennis score tracker\"},{\"body\":\"Write a short, polite message for an auto or cab driver. Ask me pickup and drop first, then include landmark and call-back line.\",\"title\":\"Message an auto or cab\"},{\"title\":\"Design a 30-minute morning\",\"body\":\"Design a calm 30-minute morning routine. Ask my must-do task first, then fit the rest around it.\"},{\"body\":\"Help me build 5 interview stories from my experience. Ask the role I’m targeting, then shape my notes into STAR answers.\",\"title\":\"Build interview story answers\"},{\"title\":\"Make a meal planning board\",\"body\":\"Create a clean visual weekly meal board with simple food icons and blank spaces I can fill. Keep text out of the image.\"},{\"title\":\"See a clear email structure\",\"body\":\"Create a text-light visual card showing the structure of a clear work email, using simple icons and blank labels I can fill in.\"},{\"title\":\"Build my kirana list\",\"body\":\"Turn my meal ideas into a kirana list. Ask for the meals first, then group staples, fresh items and top-ups.\"},{\"title\":\"Make a rainy-trip packing guide\",\"body\":\"Create a text-light packing layout image for a rainy trip, with simple item icons and empty spaces I can tick or label myself.\"},{\"body\":\"For Rath Yatra 2026, explain the main terms, the chariot symbolism and what a first-time observer should know respectfully.\",\"title\":\"Learn Rath Yatra basics\"},{\"body\":\"Practise a behavioural interview answer with me using STAR. Ask me for the role and one experience, then coach my first draft.\",\"title\":\"Practise an interview answer\"},{\"body\":\"Create a text-light Van Mahotsav sapling care card with icons for water, sun, pruning, and a blank plant name.\",\"title\":\"Make sapling care cards\"},{\"title\":\"Draw my monsoon bag map\",\"body\":\"Create a text-light monsoon bag map for my commute. Ask my city first, then make it simple, bright and printable.\"},{\"body\":\"Help me design a morning routine I can actually follow. Ask one question about my start time, then suggest a simple first week.\",\"title\":\"Design a morning routine\"},{\"body\":\"Create a simple top-down desk layout with zones for work, charging and stationery. Use icons and blank labels, not tiny text.\",\"title\":\"Draw a calmer desk layout\"},{\"body\":\"Turn my trip packing into a one-bag game. Ask where I’m going and for how many days, then give a compact list with “skip it” notes.\",\"title\":\"Pack one bag without drama\"},{\"body\":\"Create a low-stakes FIFA World Cup prediction game for friends, with simple rules and a blank score table.\",\"title\":\"Make a World Cup prediction game\"},{\"title\":\"Cook with fewer tomatoes\",\"body\":\"Plan a tomato-light Indian dinner. Give swaps for dal, sabzi and chutney, and ask what staples I have only if needed.\"},{\"body\":\"Create a simple text-light kitchen card showing tomato-light swaps for dal, sabzi and chutney. Use icons and blank labels, no brand names.\",\"title\":\"Draw tomato-light swaps\"},{\"body\":\"Ask my city, then explain today’s monsoon progress using official sources and what it may mean for the next few days.\",\"title\":\"Decode the monsoon map\"},{\"title\":\"Pack for a rainy trip\",\"body\":\"Make a practical packing list for a rainy trip. Ask me where I’m going and for how many days before you start.\"},{\"body\":\"Help me plan an F1 2026 race weekend watch setup in India. Ask which race and whether I’ll watch solo or with friends.\",\"title\":\"Set up an F1 race weekend\"},{\"body\":\"Create a simple, text-light Rath Yatra trip checklist card with icons for water, ID, medicines, and phone charging.\",\"title\":\"Make a yatra checklist card\"},{\"body\":\"Turn my morning into a low-stress routine game. Ask what time I need to leave, then build a simple countdown with buffer.\",\"title\":\"Make mornings run on rails\"},{\"title\":\"Shape a nostalgia playlist\",\"body\":\"Build a party playlist mood from current Indian YouTube music trends. Blend nostalgic Hindi and regional DJ energy without repeating one style.\"},{\"body\":\"I can upload a photo or describe the area. Give me a 30-minute declutter plan with keep, move, donate and discard steps.\",\"title\":\"Declutter a small space\"},{\"body\":\"Create a text-light interview story board with 5 blank cards. Ask my target role first, then keep it simple and editable.\",\"title\":\"Map my interview stories\"},{\"body\":\"Make a moving checklist for an Indian city apartment. Ask my move date and whether packers are involved before drafting.\",\"title\":\"Plan a home move\"},{\"title\":\"Plan a 7-day study sprint\",\"body\":\"Make a 7-day study plan for a topic I need to revise. Ask the subject and time I can spare each day.\"},{\"title\":\"Prep a cricket group chat\",\"body\":\"Make a spoiler-free group chat primer for India’s next Women’s T20 World Cup match. Include form, stakes and 3 talking points.\"},{\"body\":\"Create a simple storage-zone image for a shelf or cupboard, using blank labels and clear icons for where things should go.\",\"title\":\"Map storage zones\"},{\"title\":\"Pack for a trip neatly\",\"body\":\"Make a practical packing plan for a trip. Ask my destination and number of days, then group items by bag.\"},{\"title\":\"Catch up on Women’s T20\",\"body\":\"Give me a quick Women’s T20 World Cup catch-up for India’s campaign. Explain standings, key fixtures and what to watch next.\"},{\"title\":\"Remix a dance hook safely\",\"body\":\"Make three original Reel ideas for a new Bollywood dance song trend. No copied steps or lyrics, just fresh prompts.\"},{\"title\":\"Pick a safer monsoon break\",\"body\":\"Help me choose a monsoon weekend trip in India. Ask my starting city, then compare safer rain-season options and what to avoid.\"},{\"body\":\"Check the current FIFA World Cup fixtures and suggest one match for me to watch in India, with a quick reason and a fun talking point.\",\"title\":\"Pick a World Cup match\"},{\"title\":\"Learn monsoon snack logic\",\"body\":\"Teach me 5 Indian monsoon snacks, what makes each work with chai, and one easier home version for each.\"},{\"body\":\"Help me plan a relaxed weekend trip. Ask my starting city and travel style, then suggest 3 realistic India options.\",\"title\":\"Find a weekend trip idea\"},{\"title\":\"Create a party vibe card\",\"body\":\"Create a text-light party vibe card image inspired by current India music trends. Use abstract shapes, no artists or logos.\"},{\"title\":\"Turn study into a mini quest\",\"body\":\"Make a 7-day mini quest for learning one topic. Ask me the topic, then split it into tiny missions and a final boss quiz.\"},{\"body\":\"Create a simple, text-light visual cooking plan from my ingredients. Ask me for a fridge photo or short list first.\",\"title\":\"Visualise a simple dinner plan\"},{\"body\":\"Give me a beginner’s guide to Wimbledon 2026: how the draw works, who to watch, and which matches are friendly for India timings.\",\"title\":\"Start watching Wimbledon\"},{\"title\":\"Make a monsoon bag card\",\"body\":\"Create a text-light visual card for my monsoon commute bag. Use simple icons and leave space for me to add city-specific notes.\"},{\"body\":\"Help me write a short speech that sounds warm and natural. Ask the occasion first, then make a clean first draft.\",\"title\":\"Draft a warm short speech\"},{\"title\":\"Create a packing grid\",\"body\":\"Create a text-light packing grid for a short trip, using simple icons and blank labels. Ask the trip length first.\"},{\"title\":\"Create a football watch badge\",\"body\":\"Create a simple World Cup watch badge image with blank space for my chosen team, match time, and snacks. No official logos.\"},{\"title\":\"Tame the late kick-offs\",\"body\":\"Make an India-friendly FIFA World Cup watch plan for the next week, with sensible sleep trade-offs and one must-watch match.\"},{\"title\":\"Plan a Rath Yatra visit\",\"body\":\"Help me decide whether to attend Puri Rath Yatra. Ask my starting city, then make a practical travel and crowd-safety plan.\"},{\"body\":\"Create a gentle Rath Yatra quiz for a family chat, with easy questions, answers, and one thing to learn from each.\",\"title\":\"Make a Rath Yatra quiz\"},{\"title\":\"Polish my WhatsApp tone\",\"body\":\"I’ll paste a message. Make it warm, clear and natural in Indian English, with 3 options from polite to casual.\"},{\"title\":\"Read an esports points table\",\"body\":\"Use BMPS 2026 as an example to teach how esports points tables, placement points and kill points work.\"},{\"body\":\"Use the latest India women’s T20 World Cup scorecard to explain run rate, wickets and phases for a new fan.\",\"title\":\"Decode a T20 scorecard\"},{\"body\":\"Explain how streaming charts, platform drops and social buzz differ, using current India OTT examples.\",\"title\":\"Understand OTT buzz\"},{\"title\":\"Create a match-night snack board\",\"body\":\"Create a text-light image of a cosy football snack board for a home watch night. Use simple team-colour accents, no logos or player likenesses.\"},{\"body\":\"Explain why India Women’s Lord’s Test is a big deal, then give me three playful talking points for a cricket chat.\",\"title\":\"Decode the Lord’s Test buzz\"},{\"title\":\"Help me choose without overthinking\",\"body\":\"I’m stuck on an everyday choice. Ask me to list the options, then run a quick playful decision game with pros, trade-offs and a final pick.\"},{\"body\":\"Help me plan easy snacks and drinks for guests. Ask how many people and what I can cook, then suggest a balanced menu.\",\"title\":\"Plan snacks for guests\"},{\"body\":\"Help me read a packaged food label. I can upload a photo or type the ingredients, nutrition table and dates.\",\"title\":\"Read a food label\"},{\"body\":\"Create a simple rainy snack-board image from the items I list. Keep it text-light, cosy and realistic.\",\"title\":\"Draw a snack board\"},{\"title\":\"Compare appliance specs\",\"body\":\"Upload a photo or paste the specs for two appliances. Explain the terms and make a comparison table without telling me what to buy.\"},{\"body\":\"Make a 10-minute monsoon entryway reset for wet shoes, umbrellas and bags. Include a no-shopping version for a small flat.\",\"title\":\"Reset your rainy entryway\"},{\"body\":\"I can upload a fridge photo or list ingredients. Suggest 3 simple meals I can cook today and what I may need to buy.\",\"title\":\"Cook with what you have\"},{\"title\":\"Make dinner from what��s at home\",\"body\":\"Help me turn what I have into dinner. Ask me for a fridge photo or ingredient list, then suggest 2 simple options.\"},{\"body\":\"Act as my interviewer for a role I’m applying to. Ask the role first, then give one question at a time with feedback.\",\"title\":\"Run a mock interview\"},{\"body\":\"Create a simple icon-only monsoon commute card for India: rain alert, route check, power bank, shoes, ID, water. Keep labels blank.\",\"title\":\"Make a monsoon commute card\"},{\"title\":\"Check mosquito breeding spots\",\"body\":\"Make a 10-minute weekly home check for dengue prevention. Focus on coolers, pots, drains and stored water, without medical advice.\"},{\"title\":\"Make a tennis watch planner\",\"body\":\"Create a simple grass-court watch planner image with blank match slots. Keep it text-light, with no logos.\"},{\"body\":\"Paste a flat listing. Explain 1RK, deposit, maintenance and brokerage, then give me 5 smart questions to ask.\",\"title\":\"Decode a flat listing\"},{\"title\":\"Read today’s rain alerts\",\"body\":\"Teach me how to read IMD rain alerts for my city and turn them into a simple commute plan. Ask my city first if needed.\"},{\"title\":\"Pick my OTT mood\",\"body\":\"Without spoilers, help me decide if Raakh is too heavy for tonight. If yes, suggest a lighter watch mood instead.\"},{\"body\":\"Upload a PDF or paste the text. Summarise it in plain English and list the key decisions, dates and action items.\",\"title\":\"Summarise a document\"},{\"body\":\"Create a text-light Rath Yatra chariot craft sheet image with simple shapes and blank labels, no deity likenesses.\",\"title\":\"Create a chariot craft sheet\"},{\"title\":\"Explain a warranty clearly\",\"body\":\"Explain this warranty in plain English. I’ll upload a photo or paste the key lines. Point out questions to ask, without giving legal advice.\"},{\"title\":\"Tidy your digital files\",\"body\":\"Create a folder system for my digital files. Ask what I mostly store, then suggest folder names and simple rules.\"},{\"title\":\"Make a reading routine card\",\"body\":\"Create a calm, text-light visual card for a 20-minute reading routine, with simple step icons and space for handwritten notes.\"},{\"title\":\"Build a CUET shortlist\",\"body\":\"Help me make a CUET college preference shortlist. Ask my course first, then create a comparison table I can fill.\"},{\"title\":\"Decode Wimbledon scoring\",\"body\":\"Teach me Wimbledon scoring like I’m watching for the first time, with a playful mini quiz at the end.\"},{\"body\":\"Create a cosy, text-light image of an Indian monsoon snack platter for home inspiration. No brand names or readable labels.\",\"title\":\"Sketch a rainy snack platter\"},{\"body\":\"Help me make a spoiler-free OTT watchlist from current India releases. Ask my preferred language or mood, then suggest what to try first.\",\"title\":\"Build a spoiler-free watchlist\"},{\"body\":\"Create a text-light monsoon snack tasting sheet with five blank slots, simple spice and crunch icons, and no brand names.\",\"title\":\"Make a snack tasting sheet\"},{\"body\":\"Show me a 15-second Reel structure for teaching one small idea. Ask me for the topic first, then make a shot-by-shot plan.\",\"title\":\"Practise a 15-second Reel\"},{\"title\":\"Improve a board answer\",\"body\":\"I’ll paste a board-style answer. Improve it for marks, keep my points, and show a 3-line examiner-friendly version.\"},{\"title\":\"Check if a FASTag pass helps\",\"body\":\"Help me decide if the FASTag Annual Pass is worth checking. Ask my vehicle type and usual highway trips, then compare fit, not exact savings.\"},{\"body\":\"Help me make a travel-day plan with buffer time, snacks and document checks. Ask the journey type first.\",\"title\":\"Plan a calmer travel day\"},{\"title\":\"Plan a no-bore tiffin week\",\"body\":\"Make my next 5 tiffins feel less repetitive. Ask me for a kitchen photo or ingredient list, then suggest easy mix-and-match ideas.\"},{\"title\":\"Reset a messy space\",\"body\":\"Help me reset a messy desk or room. Ask for a photo or short description, then give me a 20-minute plan.\"},{\"title\":\"Plan a no-fuss tiffin week\",\"body\":\"Plan 5 simple tiffin ideas using Indian home staples. Ask who it is for and any food restrictions before making the plan.\"},{\"title\":\"Plan around a waitlisted ticket\",\"body\":\"My train ticket is WL or RAC. Explain what it means and help me plan a backup without guessing confirmation chances.\"},{\"title\":\"Prepare a hard conversation\",\"body\":\"Help me prepare for a difficult conversation. Ask who it is with, then draft a calm opening and likely replies.\"},{\"body\":\"Make a monsoon train carry-on list for my route. Ask destination and train class first, then keep it one-bag friendly.\",\"title\":\"Pack for a monsoon train\"},{\"title\":\"Make a chariot explainer\",\"body\":\"Create a text-light Rath Yatra learning graphic with three simple chariots, symbol icons and blank labels. No faces or logos.\"},{\"title\":\"Plan a monsoon snack\",\"body\":\"I want a rainy-day snack at home. I can upload a kitchen photo or list 3 ingredients. Suggest one quick option and a chai pairing.\"},{\"title\":\"Pick my World Cup side quest\",\"body\":\"Help me pick a fun neutral team to follow at the FIFA World Cup. Ask one question first, then give a playful shortlist.\"},{\"body\":\"Give me a beginner-friendly Wimbledon 2026 guide for watching from India. Explain the format, terms and matches to follow.\",\"title\":\"Get into Wimbledon\"},{\"title\":\"Draw a concept map\",\"body\":\"Create a simple concept map for a topic I’m studying. Ask me the topic first, then keep the image text-light.\"},{\"body\":\"Create a text-light notice graphic for an apartment water or power issue. Use blank space for timing and contact details outside the image.\",\"title\":\"Make a simple society notice\"},{\"body\":\"Teach me how to choose monsoon-friendly fabrics and footwear for daily wear, without assuming my budget or city.\",\"title\":\"Choose monsoon-friendly fabric\"},{\"body\":\"Find a current Indian regional trailer that suits a light film night, then suggest a no-spoiler watch plan.\",\"title\":\"Try a regional film night\"},{\"body\":\"Draft a polite apartment-society notice for a water cut. Ask me the date and duration first, then write group-message and notice-board versions.\",\"title\":\"Draft a society notice\"},{\"title\":\"Make a tiffin idea wheel\",\"body\":\"Create a text-light tiffin idea wheel with simple food icons and blank labels. Ask my main flavour preference first.\"},{\"body\":\"Help me prepare for a Passport Seva appointment. Ask which service it is, then make an official-doc checklist and visit-day plan.\",\"title\":\"Prep for Passport Seva\"},{\"title\":\"Draw your budget buckets\",\"body\":\"Create a simple budget bucket diagram with generic icons and three blank labels. Keep any written guidance outside the image.\"},{\"title\":\"Understand an ODI chase\",\"body\":\"Use a recent India ODI scorecard to teach me how a chase is paced: powerplay, middle overs, required run rate and wickets.\"},{\"body\":\"Help me make an ITR document folder for AY 2026-27. Ask only my income type first, then list likely documents to collect.\",\"title\":\"Sort ITR papers before filing\"},{\"body\":\"Help me sort a pile of bills, forms and notes. Ask what categories I see, then give me a quick filing plan.\",\"title\":\"Sort my paperwork pile\"},{\"title\":\"Explain the 48-team chaos\",\"body\":\"Explain the 48-team World Cup format like I’m joining a group chat late, with a tiny glossary and a playful example.\"},{\"title\":\"Learn women’s T20 terms\",\"body\":\"Explain five T20 cricket terms I’ll hear during India Women’s matches, with examples from the current World Cup.\"},{\"body\":\"Find a current Indian music trend for a short video idea. Ask what the video is about, then suggest a clean hook and caption.\",\"title\":\"Choose a Reel soundtrack\"},{\"title\":\"Draw a UPI payment flow\",\"body\":\"Create a text-light doodle showing when to use cash, UPI Lite or normal UPI. Check current rules first.\"}]},\"is_device_based\":true,\"passed\":true},\"3961845717\":{\"name\":\"3961845717\",\"rule_id\":\"6P0BG84pqTgT7X3ZW7I2O:0.00:1\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"styles\":[\"cyberpunk\",\"anime\",\"dramatic-headshot\",\"coloring-book\",\"photo-shoot\",\"retro-cartoon\",\"80s-glam\",\"art-nouveau\",\"synthwave\"]},\"is_device_based\":false,\"passed\":false},\"3131667714\":{\"name\":\"3131667714\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"regions\":[\"us\",\"eu\",\"jp\",\"au\",\"ae\",\"kr\",\"sg\",\"gb\",\"ca\",\"in\"],\"supported_regions_merge_connector\":[\"us\",\"eu\",\"jp\"]},\"is_device_based\":false,\"passed\":false},\"2542357090\":{\"name\":\"2542357090\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"stableID\",\"value\":{\"language_instructions\":{\"hi_latn\":\"Response language for the first visible response: natural Roman Hindi using Latin script only. Translate any English campaign wording before writing. Use Roman Hindi—not English—for every visible element, including the opening, lead-in, and all three clickable suggestions. Common borrowed words are fine, but never write a complete lead-in or suggestion in English. If the user later writes in another language or script, switch naturally.\",\"es\":\"Response language for the first visible response: natural Spanish. Use Spanish for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"pt\":\"Response language for the first visible response: natural Brazilian Portuguese. Use Brazilian Portuguese for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"hi\":\"Response language for the first visible response: natural Hindi in Devanagari. Translate any English campaign wording before writing. Use Devanagari Hindi for every visible element—the opening, lead-in, and all three clickable suggestions—and do not copy full English phrases into the response. If the user later writes in another language or script, switch naturally.\",\"ko\":\"Response language for the first visible response: natural Korean. Use Korean for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"ja\":\"Response language for the first visible response: natural Japanese. Use Japanese for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"en\":\"Response language for the first visible response: natural English. Use English for all visible text, including the lead-in and clickable suggestions. If the user later writes in another language, switch naturally.\",\"id\":\"Response language for the first visible response: natural Indonesian. Use Indonesian for all visible text, including the lead-in and clickable suggestions. Use standard Indonesian punctuation: keep the two opening sentences in one paragraph and end each with a period; an optional emoji may follow the first period. If the user later writes in another language, switch naturally.\"},\"default_bootstrap_model_id\":\"gpt-5-5-instant\",\"creative_to_campaign\":{\"120246696337550182\":{\"campaign_key\":\"hair_color_preview\",\"language_key\":\"es\"},\"798559023059\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"en\"},\"808801747587\":{\"campaign_key\":\"custom_event_sticker\",\"language_key\":\"hi\"},\"778169782544\":{\"language_key\":\"en\",\"campaign_key\":\"spicy_pani_puri\"},\"1867096733187154\":{\"campaign_key\":\"background_cleanup\",\"language_key\":\"es\"},\"798502712077\":{\"language_key\":\"en\",\"campaign_key\":\"spicy_pani_puri\"},\"778150297184\":{\"language_key\":\"hi\",\"campaign_key\":\"spicy_pani_puri\"},\"799705239738\":{\"campaign_key\":\"closet_room_refresh\",\"language_key\":\"en\"},\"812175322962\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"ko\"},\"801737502440\":{\"campaign_key\":\"bracelet_design\",\"language_key\":\"id\"},\"1867096724761377\":{\"campaign_key\":\"background_cleanup\",\"language_key\":\"es\"},\"807118178556\":{\"language_key\":\"ja\",\"campaign_key\":\"image_canvas\"},\"778150297187\":{\"campaign_key\":\"spicy_pani_puri\",\"language_key\":\"hi\"},\"1866355576294609\":{\"language_key\":\"ko\",\"campaign_key\":\"job_caricature\"},\"1867096731386354\":{\"campaign_key\":\"image_canvas\",\"language_key\":\"es\"},\"799747791754\":{\"campaign_key\":\"outdoor_yoga\",\"language_key\":\"id\"},\"120241043845840182\":{\"campaign_key\":\"outfit_transfer\",\"language_key\":\"en\"},\"798449148135\":{\"campaign_key\":\"cricket_catchup\",\"language_key\":\"hi_latn\"},\"812358495329\":{\"campaign_key\":\"football_bobblehead\",\"language_key\":\"hi\"},\"120245713730230182\":{\"campaign_key\