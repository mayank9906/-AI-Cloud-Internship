alse},\"3660657310\":{\"name\":\"3660657310\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"ads_segment_id\",\"value\":{\"consent_modal_enabled\":false,\"keepalive_event_logger_web\":false,\"ask_chatgpt_button_copy_key\":\"ASK_CHATGPT\",\"consent_modal_short_copy\":true,\"feedback_interested_enabled\":false,\"late_ads_event_discard_timeout_seconds\":5,\"late_ads_visibility_gate_enabled\":false,\"ask_about_ad_ephemeral_thread_panel\":false,\"show_ask_chatgpt_menu_item\":true,\"show_ask_chatgpt_button\":false,\"consent_modal_pre_selected\":true,\"consent_modal_title\":\"Make ads relevant for you\",\"android_display_zoom_scale_threshold\":0,\"consent_modal_variant\":\"\",\"late_ads_event_discard_timeout_after_slot_visibility_seconds\":1,\"late_ads_slot_visibility_threshold\":0.01},\"is_device_based\":false,\"is_in_layer\":true,\"explicit_parameters\":[\"ask_about_ad_ephemeral_thread_panel\",\"show_ask_chatgpt_button\",\"ask_chatgpt_button_copy_key\"],\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"4005134340\":{\"name\":\"4005134340\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"1007700932\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"3025475441\":{\"name\":\"3025475441\",\"rule_id\":\"5o63NJueyD2RVTKUbhegUP-5o63NHPc6kTnCucYA9iDBN\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enterprise_cbp\":false,\"self_serve_business\":true},\"is_device_based\":false,\"passed\":true},\"1812828540\":{\"name\":\"1812828540\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"is_enabled\":true},\"is_device_based\":false,\"group_name\":\"Test\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1001765573\":{\"name\":\"1001765573\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"4113286138\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"1829150232\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"690090010\":{\"name\":\"690090010\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"workspace_id\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_web_search\":false,\"user_prompt_key\":\"good_option\",\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\"},\"is_device_based\":false,\"passed\":false},\"2688454279\":{\"name\":\"2688454279\",\"rule_id\":\"default\",\"secondary_exposures\":[{\"gate\":\"2860872286\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"2428869993\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"userID\",\"value\":{\"wingman_model_name\":\"\",\"home_takeover_enabled\":false,\"wingman_model_picker_alternative_options\":[],\"unavailable_upsell_policy\":\"none\",\"home_takeover_animation_enabled\":false,\"incall_voice_model_picker_available\":false,\"wingman_model_picker_default_display_name\":\"\",\"rollout_version\":0,\"rollout_policy\":\"unavailable\",\"incall_banner_enabled\":false,\"unavailable_upsell_show_upgrade_cta\":false},\"is_device_based\":false,\"passed\":false},\"1249441125\":{\"name\":\"1249441125\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"passed\":false},\"2932422744\":{\"name\":\"2932422744\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"allow_all\":true,\"allowed_service_connector_ids\":[\"connector_2128aebfecb84f64a069897515042a44\",\"connector_947e0d954944416db111db556030eea6\",\"connector_5f3c8c41a1e54ad7a76272c89e2554fa\",\"connector_e6a7394682e24467ac68c60696f275a4\",\"connector_4aaab2856305417b993eca9a216aaf6e\",\"connector_1e4f6a44acf14e3ca1d96672f8c945bc\",\"connector_4964e3b22e3e427e9b4ae1acf2c1fa34\",\"connector_9d7cfa34e6654a5f98d3387af34b2e1c\",\"connector_6f1ec045b8fa4ced8738e32c7f74514b\",\"connector_246af0940da3457da0e751171dc1ce60\",\"connector_554ce9f9020d36085149b4f48f4032b3\",\"connector_686fad9b54914a35b75be6d06a0f6f31\",\"connector_6095bdb01e9482eb0cac719f6ba313cd\",\"connector_fcead6f527b44ea791d57da2a6022f18\",\"connector_d3ad4b4de20147a3b5cc9be604e41d4d\",\"connector_76869538009648d5b282a4bb21c3d157\"]},\"is_device_based\":false,\"passed\":false},\"21335965