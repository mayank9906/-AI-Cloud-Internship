ta-turn="assistant"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="5b3990a1-5cea-4243-b59a-e202ac77f719" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--sticky-padding-top)" dir="auto" data-turn-id="5b3990a1-5cea-4243-b59a-e202ac77f719" data-turn-id-container="5b3990a1-5cea-4243-b59a-e202ac77f719" data-testid="conversation-turn-729" data-turn="user"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="7f3519b5-d8f8-4d09-8f75-73f4c5dc5af2" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="7f3519b5-d8f8-4d09-8f75-73f4c5dc5af2" data-turn-id-container="7f3519b5-d8f8-4d09-8f75-73f4c5dc5af2" data-testid="conversation-turn-730" data-turn="assistant"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="bb84830b-5a72-40fe-9dcb-db0ed719bd61" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--sticky-padding-top)" dir="auto" data-turn-id="bb84830b-5a72-40fe-9dcb-db0ed719bd61" data-turn-id-container="bb84830b-5a72-40fe-9dcb-db0ed719bd61" data-testid="conversation-turn-731" data-turn="user"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="7459a172-b9ac-4d18-9ecc-1de43fbc41a4" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="7459a172-b9ac-4d18-9ecc-1de43fbc41a4" data-turn-id-container="7459a172-b9ac-4d18-9ecc-1de43fbc41a4" data-testid="conversation-turn-732" data-turn="assistant"></section></div><div class="h-(--last-known-height,50vh) min-h-14" data-turn-id-container="9252e48e-94e4-49d3-94d0-c4600447d813" data-is-intersecting="false"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-(--sticky-padding-top)" dir="auto" data-turn-id="9252e48e-94e4-49d3-94d0-c4600447d813" data-turn-id-container="9252e48e-94e4-49d3-94d0-c4600447d813" data-testid="conversation-turn-733" data-turn="user"></section></div><div class="" data-turn-id-container="7e3143b8-f9a5-4b0e-a8c6-e84930c7d56c" data-is-intersecting="true"><section class="text-token-text-primary w-full focus:outline-none has-data-writing-block:pointer-events-none [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto R6Vx5W_threadScrollVars scroll-mb-[calc(var(--scroll-root-safe-area-inset-bottom,0px)+var(--thread-response-height))] scroll-mt-[calc(var(--header-height)+min(200px,max(70px,20svh)))]" dir="auto" data-turn-id="7e3143b8-f9a5-4b0e-a8c6-e84930c7d56c" data-turn-id-container="7e3143b8-f9a5-4b0e-a8c6-e84930c7d56c" data-testid="conversation-turn-734" data-turn="assistant"><h4 class="sr-only select-none">ChatGPT said:</h4><div class="text-base my-auto mx-auto [--thread-content-margin:var(--thread-content-margin-xs,calc(var(--spacing)*4))] @w-sm/main:[--thread-content-margin:var(--thread-content-margin-sm,calc(var(--spacing)*6))] @w-lg/main:[--thread-content-margin:var(--thread-content-margin-lg,calc(var(--spacing)*16))] px-(--thread-content-margin)"><div data-conversation-screenshot-content="" class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="assistant" data-message-id="7e3143b8-f9a5-4b0e-a8c6-e84930c7d56c" dir="auto" data-message-model-slug="gpt-5-5" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert wrap-break-word w-full dark markdown-new-styling"><p data-start="0" data-end="100">Great question. Understanding <strong data-start="30" data-end="37">WSL</strong> will also help you understand <strong data-start="68" data-end="99">why Docker works on Windows</strong>.</p>
<hr data-start="102" data-end="105">
<h1 data-section-id="q9vz5" data-start="107" data-end="121">What is WSL?</h1>
<p data-start="123" data-end="160"><strong data-start="123" data-end="160">WSL = Windows Subsystem for Linux</strong></p>
<p data-start="162" data-end="184">Think of it like this:</p>
<p data-start="186" data-end="225">Normally your computer looks like this:</p>
<pre class="overflow-visible! px-0!" data-start="227" data-end="292"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-16f983c9.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>Windows</span><br><span>│</span><br><span>├── VS Code</span><br><span>├── Chrome</span><br><span>├── Python</span><br><span>└── Games</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="294" data-end="345">WSL adds a <strong data-start="305" data-end="344">small Linux computer inside Windows</strong>.</p>
<pre class="overflow-visible! px-0!" data-start="347" data-end="499"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-16f983c9.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>Windows</span><br><span>│</span><br><span>├── VS Code</span><br><span>├── Chrome</span><br><span>├── Python</span><br><span>│</span><br><span>└── WSL (Mini Linux)</span><br><span>      │</span><br><span>      ├── Ubuntu</span><br><span>      ├── Linux Commands</span><br><span>      └── Docker Engine</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="501" data-end="604">So you're still using Windows, but Windows can now run Linux software without needing another computer.</p>
<hr data-start="606" data-end="609">
<h1 data-section-id="pk0gx6" data-start="611" data-end="651">Why did Docker ask you to install WSL?</h1>
<p data-start="653" data-end="706">Most servers in the world run <strong data-start="683" data-end="692">Linux</strong>, not Windows.</p>
<p data-start="708" data-end="720">For example:</p>
<ul data-start="722" data-end="786">
<li data-section-id="17n9ypl" data-start="722" data-end="731">
<p data-start="724" data-end="731">AWS EC2</p>
</li>
<li data-section-id="80bbk6" data-start="732" data-end="756">
<p data-start="734" data-end="756">Azure Virtual Machines</p>
</li>
<li data-section-id="1atkup7" data-start="757" data-end="786">
<p data-start="759" data-end="786">Google Cloud Compute Engine</p>
</li>
</ul>
<p data-start="788" data-end="811">Most of them use Linux.</p>
<p data-start="813" data-end="855">Docker containers are also based on Linux.</p>
<p data-start="857" data-end="930">Instead of translating Linux into Windows every time, Docker simply says:</p>
<blockquote data-start="932" data-end="970">
<p data-start="934" data-end="970">"I'll run my containers inside WSL."</p>
</blockquote>
<p data-start="972" data-end="991">That's much faster.</p>
<hr data-start="993" data-end="996">
<h1 data-section-id="1p25e53" data-start="998" data-end="1010">Before WSL</h1>
<p data-start="1012" data-end="1034">People had to install:</p>
<ul data-start="1036" data-end="1057">
<li data-section-id="271se4" data-start="1036" data-end="1048">
<p data-start="1038" data-end="1048">VirtualBox</p>
</li>
<li data-section-id="9xdms2" data-start="1049" data-end="1057">
<p data-start="1051" data-end="1057">VMware</p>
</li>
</ul>
<p data-start="1059" data-end="1089">Then install Ubuntu inside it.</p>
<p data-start="1091" data-end="1111">It looked like this:</p>
<pre class="overflow-visible! px-0!" data-start="1113" data-end="1174"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-16f983c9.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>Windows</span><br><br><span>↓</span><br><br><span>Virtual Machine</span><br><br><span>↓</span><br><br><span>Ubuntu</span><br><br><span>↓</span><br><br><span>Docker</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="1176" data-end="1199">Very slow.<br>
Lots of RAM.</p>
<hr data-start="1201" data-end="1204">
<h1 data-section-id="1ntw0lm" data-start="1206" data-end="1217">After WSL</h1>
<p data-start="1219" data-end="1235">Now it's simply:</p>
<pre class="overflow-visible! px-0!" data-start="1237" data-end="1275"><div class="relative w-full mt-4 mb-1"><div class=""><div class="contents"><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1"><button type="button" class="flex gap-1 items-center select-none pointer-events-auto py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-16f983c9.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="relative"><div class="pe-11 pt-3" style="transform: none;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>Windows</span><br><br><span>↓</span><br><br><span>WSL</span><br><br><span>↓</span><br><br><span>Docker</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></pre>
<p data-start="1277" data-end="1301">Much lighter and faster.</p>
<hr data-start="1303" data-end="1306">
<h1 data-section-id="yz5rga" data-start="1308" data-end="1336">Why didn't you notice WSL?</h1>
<p data-start="1338" data-end="1383">Because Microsoft integrated it into Windows.</p>
<p data-start="1385" data-end="1471">You can even open Ubuntu from the Start Menu if you've installed a Linux distribution.</p>
<hr data-start="1473" data-end="1476">
<h1 data-section-id="11wlvff" data-start="1478" data-end="1498">Real-world example</h1>
<p data-start="1500" data-end="1543">Suppose you're making your LegalAI project.</p>
<p data-start="1545" data-end="1568">You develop on Windows.</p>
<p data-start="1570" data-end="1613">When deploying to AWS, the server is Linux.</p>
<p data-start="1615" data-end="1674">With WSL, you can test Linux commands <strong data-start="1653" data-end="1673">before deploying</strong>.</p>
<p data-start="1676" data-end="1688">For example:</p>
<p data-start="1690" data-end="1709">Instead of Windows:</p>
