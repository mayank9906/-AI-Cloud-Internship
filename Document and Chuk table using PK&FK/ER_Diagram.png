<p data-start="935" data-end="950">You should see:</p>
<div class="TyagGW_tableContainer"><div tabindex="-1" class="group TyagGW_tableWrapper flex flex-col-reverse w-fit"><table data-start="952" data-end="1160" class="w-fit min-w-(--thread-content-width)"><thead data-start="952" data-end="1006"><tr data-start="952" data-end="1006"><th data-start="952" data-end="963" data-col-size="sm" class="last:pe-10">chunk_id</th><th data-start="963" data-end="977" data-col-size="sm" class="last:pe-10">document_id</th><th data-start="977" data-end="990" data-col-size="sm" class="last:pe-10">chunk_text</th><th data-start="990" data-end="1006" data-col-size="sm" class="last:pe-10">chunk_number</th></tr></thead><tbody data-start="1062" data-end="1160"><tr data-start="1062" data-end="1094"><td data-start="1062" data-end="1066" data-col-size="sm">1</td><td data-start="1066" data-end="1070" data-col-size="sm">1</td><td data-start="1070" data-end="1089" data-col-size="sm">This is chunk 1.</td><td data-start="1089" data-end="1094" data-col-size="sm">1</td></tr><tr data-start="1095" data-end="1127"><td data-start="1095" data-end="1099" data-col-size="sm">2</td><td data-start="1099" data-end="1103" data-col-size="sm">1</td><td data-start="1103" data-end="1122" data-col-size="sm">This is chunk 2.</td><td data-start="1122" data-end="1127" data-col-size="sm">2</td></tr><tr data-start="1128" data-end="1160"><td data-start="1128" data-end="1132" data-col-size="sm">3</td><td data-start="1132" data-end="1136" data-col-size="sm">1</td><td data-start="1136" data-end="1155" data-col-size="sm">This is chunk 3.</td><td data-start="1155" data-end="1160" data-col-size="sm">3</td></tr></tbody></table><div class="relative h-0 self-end select-none"><div class="absolute end-0 flex items-end" style="height: 32.7969px;"><span class="" data-state="closed"><button aria-label="Copy table" class="hover:bg-token-bg-tertiary text-token-text-secondary relative z-10 my-1 rounded-sm p-1 transition-opacity group-[:not(:hover):not(:focus-within)]:pointer-events-none group-[